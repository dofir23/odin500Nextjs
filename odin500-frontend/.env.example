# Odin500 frontend — environment variables (copy to .env)

# Backend API (optional — auto-detected if omitted)
# Local `npm run dev` → http://localhost:5000
# Deployed production → NEXT_PUBLIC_API_ORIGIN or Railway default below
# API_ORIGIN=https://odin500-1-production.up.railway.app
# NEXT_PUBLIC_API_ORIGIN=https://odin500-1-production.up.railway.app
# SSR_API_ORIGIN=   # server-only override (wins over auto-detect)

# Weekly newsletter auto-generation (optional — template fallback without key)
OPENAI_API_KEY=
OPENAI_NEWSLETTER_MODEL=gpt-4o-mini
OPENAI_API_TIMEOUT_MS=60000

# Analytics & Search Console
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
