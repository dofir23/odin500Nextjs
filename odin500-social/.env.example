# Server
PORT=8080
NODE_ENV=production

# Odin500 backend (production or staging)
ODIN_API_ORIGIN=https://odin500-1-production.up.railway.app
# Bearer JWT for /api/market/* (service account or long-lived token). Optional if API allows public reads.
ODIN_API_TOKEN=

# Public site (UTM links in posts)
ODIN_SITE_ORIGIN=https://www.odin500.com

# Clean post links by default. Set true to append ?utm_source=... tracking params.
SOCIAL_UTM_ENABLED=false

# Protect manual job triggers: POST /jobs/:name with header x-social-secret
SOCIAL_INTERNAL_SECRET=change-me-in-production

# Slack / Discord approval webhook (optional) — posts preview on generate
SOCIAL_WEBHOOK_URL=

# OpenAI — social post copy (falls back to template if missing)
OPENAI_API_KEY=
OPENAI_SOCIAL_MODEL=gpt-4o-mini
OPENAI_API_TIMEOUT_MS=45000

# Page snapshots (Puppeteer) — charts from live odin500.com pages
SNAPSHOT_ENABLED=true
SNAPSHOT_TIMEOUT_MS=90000
SNAPSHOT_SETTLE_MS=3500
SNAPSHOT_VIEWPORT_WIDTH=1400
SNAPSHOT_VIEWPORT_HEIGHT=900
SNAPSHOT_DEVICE_SCALE=2
# Railway/Linux: set to system Chromium if bundled browser fails
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium

# Cron (America/New_York). Disable with CRON_ENABLED=false
CRON_ENABLED=true
# Weekdays: market close recap 4:20pm ET
CRON_DAILY_PULSE=20 16 * * 1-5
# Tue/Thu 12:30pm ET — ticker spotlight
CRON_TICKER_SPOTLIGHT=30 12 * * 2,4
# Sunday 10:00am ET — newsletter promo
CRON_NEWSLETTER=0 10 * * 0

# Timezone for cron
TZ=America/New_York
